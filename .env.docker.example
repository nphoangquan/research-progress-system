# Sao chép thành .env.docker. Compose nạp file này cho dịch vụ db và backend (env_file).
# Không commit .env.docker — trong .gitignore.

# --- Bắt buộc ---

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=research_progress

# pgAdmin desktop / tool trên máy: kết nối localhost:5432 + POSTGRES_* bên dưới. Adminer (container): :8080, Server db.

# Chuỗi kết nối Prisma — dùng tên dịch vụ Docker, không dùng localhost
DATABASE_URL=postgresql://postgres:your_secure_password@db:5432/research_progress

# JWT — dev có thể dùng giá trị mặc định; production phải đổi
JWT_SECRET=dev-secret-change-in-production

NODE_ENV=production

# --- Tùy chọn: ứng dụng ---

PORT=3000

# Web (bind) — 0.0.0.0 trong Docker
HOST=0.0.0.0

# Thư mục trong container (volume gắn vào)
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs

# CORS — origin frontend, ví dụ http://localhost hoặc https://your-domain
CORS_ORIGIN=http://localhost

# Mức log: error | warn | info | http | debug (xem backend/src/logger.ts)
LOG_LEVEL=info

# --- Tùy chọn: email (bỏ trống SMTP → backend vẫn chạy) ---
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Research Progress <no-reply@example.com>"
#
# FE_URL=http://localhost
# PASSWORD_RESET_TOKEN_EXPIRES_IN=3600000

# --- Chạy script trên máy (Node) vào DB trong Docker ---
# Stack: docker compose up -d (db publish 5432 → localhost).
# .env.docker dùng host "db" — chỉ cho container. Script npm chạy TRÊN WINDOWS → dùng backend/.env:
#   DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@127.0.0.1:5432/POSTGRES_DB
# (cùng user/pass/db với .env.docker; chỉ đổi host db → 127.0.0.1)
#
# Từ thư mục backend, sau khi npm install:
#   npx prisma generate
#   npx prisma db seed                    # dữ liệu demo (RESET_DATA=true nếu muốn xóa sạch trước — MẤT DATA)
#   npm run seed-bulk                     # thêm nhiều bản ghi [Bulk Seed] (mặc định ~120 project)
#   $env:BULK_SEED_PROJECTS=200; npm run seed-bulk          # PowerShell: tùy số lượng
#   $env:BULK_SEED_RESET=1; npm run seed-bulk                # xóa [Bulk Seed] cũ rồi tạo lại
# Trong backend/.env cần OPENAI_API_KEY rồi:
#   npm run sync-embeddings               # sinh vector cho semantic search (tốn API, lâu nếu nhiều row)
#   npm run sync-embeddings -- projects   # chỉ bảng projects

# --- Tùy chọn: embedding / tìm semantic (pgvector) ---
#
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# VECTOR_SEARCH_ENABLED=true

# --- Tùy chọn: Cloudinary (upload ảnh) ---
#
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
