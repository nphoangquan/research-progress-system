# Sao chép thành .env.docker. Compose nạp file này cho dịch vụ db và backend (env_file).
# Không commit .env.docker — trong .gitignore.

# --- Bắt buộc ---

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=research_progress

# pgAdmin desktop / tool trên máy: kết nối localhost:5432 + POSTGRES_* bên dưới. Adminer (container): :8080, Server db.

# Chuỗi kết nối Prisma — dùng tên dịch vụ Docker, không dùng localhost
DATABASE_URL=postgresql://postgres:your_secure_password@db:5432/research_progress

# JWT — dev có thể dùng giá trị mặc định; production phải đổi
JWT_SECRET=dev-secret-change-in-production

NODE_ENV=production

# --- Tùy chọn: ứng dụng ---

PORT=3000

# Web (bind) — 0.0.0.0 trong Docker
HOST=0.0.0.0

# Thư mục trong container (volume gắn vào)
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs

# CORS — origin frontend, ví dụ http://localhost hoặc https://your-domain
CORS_ORIGIN=http://localhost

# Mức log: error | warn | info | http | debug (xem backend/src/logger.ts)
LOG_LEVEL=info

# --- Tùy chọn: email (bỏ trống SMTP → backend vẫn chạy) ---
#
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Research Progress <no-reply@example.com>"
#
# FE_URL=http://localhost
# PASSWORD_RESET_TOKEN_EXPIRES_IN=3600000

# --- Tùy chọn: embedding / tìm semantic (pgvector) ---
#
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# VECTOR_SEARCH_ENABLED=true

# --- Tùy chọn: Cloudinary (upload ảnh) ---
#
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
